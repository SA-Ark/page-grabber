{
  "manifest_version": 3,
  "name": "Page Grabber",
  "version": "1.1.0",
  "description": "One-click full-page text extraction with auto-pagination and WebSocket bridge for remote automation. Saves timestamped .txt or .json files for LLM workflows.",
  "permissions": ["activeTab", "scripting", "downloads", "clipboardWrite", "storage", "tabs", "debugger"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grab this page",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": { "service_worker": "background.js" }
}
